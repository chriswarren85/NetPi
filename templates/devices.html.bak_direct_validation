{% extends 'base.html' %}
{% block title %}— Devices
{% block content %}
<div class="page-title">Devices</div>
<div class="page-sub">Define devices to check during diagnostics</div>
<div id="success" class="success-msg">Device list saved.</div>

<div class="panel">
  <div class="panel-header">Add device</div>
  <div class="panel-body">
    <div class="form-row">
      <div class="form-group">
        <label>Device name</label>
        <input id="new-name" placeholder="e.g. Barco CTRL Server">
      </div>
      <div class="form-group">
        <label>IP address</label>
        <input id="new-ip" placeholder="e.g. 192.168.1.10">
      </div>
      <div class="form-group">
        <label>Device type</label>
        <select id="new-type">
          <option value="generic">Generic</option>
          <option value="crestron">Crestron</option>
          <option value="barco_ctrl">Barco CTRL</option>
          <option value="novastar">Novastar</option>
          <option value="dante">Dante</option>
          <option value="sacn">sACN node</option>
          <option value="artnet">Art-Net node</option>
          <option value="grandma">GrandMA</option>
        </select>
      </div>
      <div class="form-group">
        <label>VLAN</label>
        <select id="new-vlan">
          <option value="">Unassigned</option>
          {% for v in s.vlans %}
          <option value="{{ v.name }}">{{ v.name }}</option>
          {% endfor %}
        </select>
      </div>
      <div class="form-group">
        <label>Notes</label>
        <input id="new-notes" placeholder="Optional notes">
      </div>
      <div class="form-group" style="display:flex;align-items:flex-end">
        <button class="btn btn-primary" onclick="addDevice()">Add</button>
      </div>
    </div>
  </div>
</div>

  <div class="panel">
    <div class="panel-header">Paste Device List</div>
    <div class="panel-body">

      <textarea id="pasted-device-text"
        style="width:100%; min-height:160px; font-family:monospace;"
        placeholder="Name	IP	VLAN	Type	Vendor
DSP-01	192.168.1.20	10		Biamp
SW-01	192.168.1.10	10		Cisco"></textarea>

      <div style="margin-top:10px; display:flex; gap:8px; flex-wrap:wrap;">
        <button class="btn" onclick="previewPasteDevices()">👁 Preview</button>
        <button class="btn btn-primary" onclick="addPastedToList()">➕ Add to Device List</button>
        <button class="btn" onclick="clearPaste()">✖ Clear</button>
      </div>

      <div id="paste-summary" style="margin-top:10px;"></div>
      <div id="paste-invalid" style="margin-top:10px;"></div>
      <div id="paste-preview" style="margin-top:10px; overflow-x:auto;"></div>

    </div>
  </div>

<div class="panel">
  <div class="panel-header">Filter</div>
  <div class="panel-body">
    <div class="form-row">
      <div class="form-group" style="max-width:260px">
        <label>Show VLAN</label>
        <select id="filter-vlan" onchange="renderTable()">
          <option value="">All VLANs</option>
          {% for v in s.vlans %}
          <option value="{{ v.name }}">{{ v.name }}</option>
          {% endfor %}
        </select>
      </div>
    </div>
  </div>
</div>

<div class="panel">
  <div class="panel-header">
    <span>Device list</span>
    <button class="btn" onclick="saveDevices()">Save changes</button>
  </div>
  <div class="panel-body" style="padding:0">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>IP</th>
          <th>Type</th>
          <th>VLAN</th>
          <th>Notes</th>
          <th></th>
        </tr>
      </thead>
      <tbody id="device-table">
        {% for d in devices %}
        <tr>
          <td>{{ d.name }}</td>
          <td style="font-family:monospace">{{ d.ip }}</td>
          <td>{{ d.type }}</td>
          <td>{{ d.vlan or '' }}</td>
          <td style="color:#6b7280">{{ d.notes or '' }}</td>
          <td><button class="btn btn-danger" onclick="removeDevice('{{ d.ip }}')">Remove</button></td>
        </tr>
        {% else %}
        <tr><td colspan="6" style="color:#4b5563;text-align:center;padding:1rem">No devices yet — add one above</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

<script>
let deviceList = {{ devices | tojson }};
let pastedPreview = [];

function escapeHtml(str){
  return String(str || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
}

function addDevice(){
  const name  = document.getElementById('new-name').value.trim();
  const ip    = document.getElementById('new-ip').value.trim();
  const type  = document.getElementById('new-type').value;
  const vlan  = document.getElementById('new-vlan').value;
  const notes = document.getElementById('new-notes').value.trim();

  if(!name || !ip){
    alert('Name and IP are required');
    return;
  }

  deviceList.push({name, ip, type, vlan, notes});
  renderTable();

  document.getElementById('new-name').value = '';
  document.getElementById('new-ip').value = '';
  document.getElementById('new-notes').value = '';
  document.getElementById('new-vlan').value = '';
}

function removeDevice(ip){
  deviceList = deviceList.filter(d => d.ip !== ip);
  renderTable();
}

function renderTable(){
  if (typeof deviceList !== 'undefined') {
    window.devices = deviceList;
  }
  const tbody = document.getElementById('device-table');
  const filterVlan = document.getElementById('filter-vlan').value;
  tbody.innerHTML = '';

  let filtered = deviceList;
  if(filterVlan){
    filtered = deviceList.filter(d => (d.vlan || '') === filterVlan);
  }

  if(filtered.length === 0){
    tbody.innerHTML = '<tr><td colspan="6" style="color:#4b5563;text-align:center;padding:1rem">No matching devices</td></tr>';
    return;
  }

  const groups = {};
  filtered.forEach(d => {
    const key = d.vlan || 'Unassigned';
    if(!groups[key]) groups[key] = [];
    groups[key].push(d);
  });

  Object.keys(groups).sort().forEach(groupName => {
    const groupRow = document.createElement('tr');
    groupRow.innerHTML = '<td colspan="6" style="background:#111827;color:#e5e7eb;font-weight:600">' + escapeHtml(groupName) + '</td>';
    tbody.appendChild(groupRow);

    groups[groupName].forEach(d => {
      const tr = document.createElement('tr');
      tr.innerHTML =
        '<td>' + escapeHtml(d.name) + '</td>' +
        '<td style="font-family:monospace">' + escapeHtml(d.ip) + '</td>' +
        '<td>' + escapeHtml(d.type) + '</td>' +
        '<td>' + escapeHtml(d.vlan || '') + '</td>' +
        '<td style="color:#6b7280">' + escapeHtml(d.notes || '') + '</td>' +
        '<td><button class="btn btn-danger" onclick="removeDevice(\'' + String(d.ip).replace(/'/g, "\'") + '\')">Remove</button></td>';
      tbody.appendChild(tr);
    });
  });
}

async function previewPasteDevices(){
  const pasted = document.getElementById('pasted-device-text').value.trim();
  if(!pasted){
    alert('Paste something first');
    return;
  }

  try {
    const res = await fetch('/tools/api/devices/preview_pasted', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ text: pasted })
    });

    const data = await res.json();

    if(!data.ok){
      alert(data.error || 'Preview failed');
      return;
    }

    pastedPreview = data.devices || [];

    document.getElementById('paste-summary').innerHTML =
      '<div style="color:#6b7280"><strong>Preview:</strong> valid ' +
      data.rows_valid + ' | invalid ' +
      data.rows_invalid + ' | duplicates ' +
      data.rows_duplicate + ' | headers detected: ' +
      (data.headers_detected ? 'yes' : 'no') + '</div>';

    if(data.invalid_rows && data.invalid_rows.length){
      document.getElementById('paste-invalid').innerHTML =
        '<details>' +
        '<summary><strong>Invalid rows (' + data.invalid_rows.length + ')</strong></summary>' +
        '<pre style="white-space:pre-wrap;font-size:11px;color:#9ca3af">' +
        escapeHtml(JSON.stringify(data.invalid_rows, null, 2)) +
        '</pre></details>';
    } else {
      document.getElementById('paste-invalid').innerHTML = '';
    }

    const rows = pastedPreview.map(d => {
      const rowStyle = d.duplicate ? ' style="background:#3f3f00"' : '';
      const status = d.duplicate ? 'Skip duplicate' : 'Ready';
      return '<tr' + rowStyle + '>' +
        '<td>' + escapeHtml(d.name) + '</td>' +
        '<td style="font-family:monospace">' + escapeHtml(d.ip) + '</td>' +
        '<td>' + escapeHtml(d.type) + '</td>' +
        '<td>' + escapeHtml(d.vlan || '') + '</td>' +
        '<td>' + escapeHtml(d.vendor || '') + '</td>' +
        '<td>' + status + '</td>' +
      '</tr>';
    }).join('');

    document.getElementById('paste-preview').innerHTML =
      '<table>' +
        '<thead>' +
          '<tr><th>Name</th><th>IP</th><th>Type</th><th>VLAN</th><th>Vendor</th><th>Status</th></tr>' +
        '</thead>' +
        '<tbody>' + rows + '</tbody>' +
      '</table>';
  } catch (e) {
    alert('Preview failed: ' + e);
  }
}

function addPastedToList(){
  if(!pastedPreview.length){
    alert('Preview first');
    return;
  }

  let added = 0;

  pastedPreview.forEach(d => {
    if(deviceList.some(x => x.ip === d.ip)) return;

    deviceList.push({
      name: d.name,
      ip: d.ip,
      type: d.type,
      vlan: d.vlan || '',
      notes: d.notes || ''
    });

    added++;
  });

  renderTable();
  alert('Added ' + added + ' devices to list. Click Save changes to write them to devices.json.');
}

function clearPaste(){
  document.getElementById('pasted-device-text').value = '';
  document.getElementById('paste-summary').innerHTML = '';
  document.getElementById('paste-invalid').innerHTML = '';
  document.getElementById('paste-preview').innerHTML = '';
  pastedPreview = [];
}

function saveDevices(){
  fetch('/tools/api/devices/save', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({devices: deviceList})
  }).then(r => r.json()).then(d => {
    if(d.success){
      document.getElementById('success').style.display = 'block';
      setTimeout(() => document.getElementById('success').style.display = 'none', 3000);
    }
  });
}

renderTable();
</script>
{% endblock %}


<!-- NetPi Validation UI -->
<style>
  .validation-summary {
    margin-top: 6px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .validation-results {
    padding: 8px 10px;
    background: #111827;
    border: 1px solid #2d3748;
    border-radius: 8px;
    margin: 6px 0 10px 0;
  }

  .validation-results-title {
    font-size: 12px;
    font-weight: 700;
    margin-bottom: 6px;
    opacity: 0.9;
  }

  .validation-badge {
    display: inline-block;
    padding: 3px 8px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    margin: 2px 6px 2px 0;
  }

  .validation-pass {
    background: #14532d;
    color: #dcfce7;
  }

  .validation-fail {
    background: #7f1d1d;
    color: #fee2e2;
  }

  .validation-warn {
    background: #78350f;
    color: #fef3c7;
  }

  .validation-error {
    background: #581c87;
    color: #f3e8ff;
  }

  .validation-muted {
    opacity: 0.75;
    font-size: 11px;
    margin-top: 4px;
  }

  .validation-cell {
    min-width: 180px;
  }

  .validation-inline-actions {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .btn-validation-running {
    opacity: 0.7;
    pointer-events: none;
  }

  tr.validation-detail-row td {
    padding-top: 0 !important;
  }
</style>

<script>
(function(){
  if (window.__netpiValidationUIInstalled) return;
  window.__netpiValidationUIInstalled = true;

  window.netpiValidationResults = window.netpiValidationResults || {};
  window.netpiValidationBusy = false;

  function escapeHtml(value) {
    return String(value || "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function statusClass(status) {
    if (status === "pass") return "validation-pass";
    if (status === "fail") return "validation-fail";
    if (status === "warn") return "validation-warn";
    if (status === "error") return "validation-error";
    return "validation-warn";
  }

  function renderResultBadges(result) {
    if (!result || !result.results || !result.results.length) {
      return '<div class="validation-muted">No validation results yet</div>';
    }

    return result.results.map(function(item) {
      var detail = item.detail ? ' title="' + escapeHtml(item.detail) + '"' : '';
      var label = escapeHtml(item.check + ': ' + item.status);
      return '<span class="validation-badge ' + statusClass(item.status) + '"' + detail + '>' + label + '</span>';
    }).join('');
  }

  function renderSummary(result) {
    if (!result) return '<div class="validation-muted">Not run</div>';

    var overall = result.overall || "warn";
    var extra = '';

    if (result.results && result.results.length) {
      var passCount = result.results.filter(function(r){ return r.status === "pass"; }).length;
      var failCount = result.results.filter(function(r){ return r.status === "fail"; }).length;
      var warnCount = result.results.filter(function(r){ return r.status === "warn" || r.status === "error"; }).length;
      extra = '<div class="validation-muted">Pass: ' + passCount + ' | Fail: ' + failCount + ' | Warn: ' + warnCount + '</div>';
    }

    return ''
      + '<div class="validation-summary">'
      +   '<span class="validation-badge ' + statusClass(overall) + '">Overall: ' + escapeHtml(overall) + '</span>'
      + '</div>'
      + extra;
  }

  function buildDetailRow(result, colspan) {
    var tr = document.createElement('tr');
    tr.className = 'validation-detail-row';

    var td = document.createElement('td');
    td.colSpan = colspan;

    td.innerHTML =
      '<div class="validation-results">'
      + '<div class="validation-results-title">Validation Results</div>'
      + renderResultBadges(result)
      + '</div>';

    tr.appendChild(td);
    return tr;
  }

  async function apiPost(url, payload) {
    const response = await fetch(url, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload || {})
    });

    const text = await response.text();

    try {
      return JSON.parse(text);
    } catch (e) {
      throw new Error("Non-JSON response: " + text);
    }
  }

  function findPrimaryTable() {
    var tables = Array.from(document.querySelectorAll('table'));
    if (!tables.length) return null;
    return tables[0];
  }

  function ensureValidateAllButton() {
    if (document.getElementById('validate-all-devices-btn')) return;

    var allButtons = Array.from(document.querySelectorAll('button'));
    var saveBtn = allButtons.find(function(btn) {
      return (btn.getAttribute('onclick') || '').indexOf('saveDevices') !== -1
        || (btn.textContent || '').toLowerCase().indexOf('save') !== -1;
    });

    var btn = document.createElement('button');
    btn.id = 'validate-all-devices-btn';
    btn.className = 'btn';
    btn.textContent = '✅ Validate All Devices';
    btn.onclick = function() { validateAllDevices(); };

    if (saveBtn && saveBtn.parentNode) {
      saveBtn.parentNode.insertBefore(btn, saveBtn.nextSibling);
    } else {
      var table = findPrimaryTable();
      if (table && table.parentNode) {
        table.parentNode.insertBefore(btn, table);
      } else {
        document.body.insertBefore(btn, document.body.firstChild);
      }
    }
  }

  function enhanceValidationUI() {
    ensureValidateAllButton();

    var table = findPrimaryTable();
    if (!table) return;
    if (!window.devices || !Array.isArray(window.devices)) return;

    var theadRow = table.querySelector('thead tr') || table.querySelector('tr');
    if (!theadRow) return;

    if (!theadRow.querySelector('.validation-header-cell')) {
      var th = document.createElement('th');
      th.textContent = 'Validation';
      th.className = 'validation-header-cell';
      theadRow.appendChild(th);
    }

    var tbody = table.querySelector('tbody') || table;
    var rows = Array.from(tbody.children).filter(function(el) {
      return el.tagName === 'TR' && !el.classList.contains('validation-detail-row');
    });

    rows.forEach(function(row, index) {
      var existingCell = row.querySelector('.validation-cell');
      if (existingCell) existingCell.remove();

      if (row.nextElementSibling && row.nextElementSibling.classList.contains('validation-detail-row')) {
        row.nextElementSibling.remove();
      }

      var device = window.devices[index];
      if (!device) return;

      var ip = device.ip || '';
      var result = window.netpiValidationResults[ip];

      var td = document.createElement('td');
      td.className = 'validation-cell';

      td.innerHTML =
        '<div class="validation-inline-actions">'
        + '<button class="btn" onclick="validateDevice(\'' + String(ip).replace(/'/g, "\\'") + '\')">✅ Validate</button>'
        + renderSummary(result)
        + '</div>';

      row.appendChild(td);

      if (result) {
        var colspan = row.children.length;
        var detailRow = buildDetailRow(result, colspan);
        row.parentNode.insertBefore(detailRow, row.nextSibling);
      }
    });
  }

  async function validateDevice(ip) {
    try {
      const result = await apiPost('/tools/api/validate_device', { ip: ip });
      if (!result.ok) {
        alert(result.error || 'Validation failed');
        return;
      }
      window.netpiValidationResults[ip] = result.result;
      enhanceValidationUI();
    } catch (err) {
      alert('Validation error: ' + err.message);
    }
  }

  async function validateAllDevices() {
    if (window.netpiValidationBusy) return;
    window.netpiValidationBusy = true;

    var btn = document.getElementById('validate-all-devices-btn');
    var originalText = btn ? btn.textContent : '';
    if (btn) {
      btn.textContent = '⏳ Validating...';
      btn.classList.add('btn-validation-running');
    }

    try {
      const result = await apiPost('/tools/api/validate_all', {});
      if (!result.ok) {
        alert(result.error || 'Validate all failed');
        return;
      }

      (result.results || []).forEach(function(item) {
        if (item && item.ip) {
          window.netpiValidationResults[item.ip] = item;
        }
      });

      enhanceValidationUI();
    } catch (err) {
      alert('Validate all error: ' + err.message);
    } finally {
      window.netpiValidationBusy = false;
      if (btn) {
        btn.textContent = originalText || '✅ Validate All Devices';
        btn.classList.remove('btn-validation-running');
      }
    }
  }

  window.validateDevice = validateDevice;
  window.validateAllDevices = validateAllDevices;

  if (typeof window.renderTable === 'function' && !window.__netpiValidationWrappedRender) {
    window.__netpiValidationWrappedRender = true;
    var originalRenderTable = window.renderTable;
    window.renderTable = function() {
      originalRenderTable.apply(this, arguments);
      enhanceValidationUI();
    };
  }

  document.addEventListener('DOMContentLoaded', function() {
    setTimeout(enhanceValidationUI, 100);
  });

  window.addEventListener('load', function() {
    setTimeout(enhanceValidationUI, 200);
  });
})();
</script>


{% endblock %}
